PAPERCLIP_IMAGE=ghcr.io/paperclipai/paperclip:latest
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

POSTGRES_DB=paperclip
POSTGRES_USER=paperclip
POSTGRES_PASSWORD=paperclip

PAPERCLIP_PORT=3100
PAPERCLIP_PUBLIC_URL=http://localhost:3100
PAPERCLIP_ALLOWED_HOSTNAMES=localhost,127.0.0.1,paperclip,host.docker.internal
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_TOKEN=replace-with-a-long-random-token
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1
OPENCLAW_TZ=Europe/Samara
