#!/bin/sh
set -e
INFRA_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
cd "$INFRA_DIR" || exit 1
if [ ! -f .env ]; then
  echo "нет файла .env в $INFRA_DIR" >&2
  exit 1
fi
set -a
. ./.env
set +a
if [ -z "${POSTGRES_PASSWORD+x}" ] || [ -z "$POSTGRES_PASSWORD" ]; then
  echo "в .env нужен непустой POSTGRES_PASSWORD" >&2
  exit 1
fi
if [ "$#" -ne 2 ]; then
  echo "использование: $0 <username> <password>" >&2
  exit 1
fi
username=$1
password=$2
case $username in
  *[!a-zA-Z0-9_]*|'')
    echo "username: только буквы, цифры и подчёркивание, не пустой" >&2
    exit 1
    ;;
esac
if [ -z "$password" ]; then
  echo "password не может быть пустым" >&2
  exit 1
fi
pw_sql=$(printf '%s' "$password" | sed "s/'/''/g")
run_psql() {
  docker compose exec -T -e "PGPASSWORD=$POSTGRES_PASSWORD" postgres \
    psql -v ON_ERROR_STOP=1 -h 127.0.0.1 --username usov --dbname usov "$@"
}
if [ "$(run_psql -tAc "SELECT 1 FROM pg_roles WHERE rolname = '$username'")" = "1" ]; then
  echo "роль уже существует: $username" >&2
  exit 1
fi
if [ "$(run_psql -tAc "SELECT 1 FROM pg_database WHERE datname = '$username'")" = "1" ]; then
  echo "база уже существует: $username" >&2
  exit 1
fi
run_psql -c "CREATE USER $username WITH ENCRYPTED PASSWORD '$pw_sql';"
run_psql -c "CREATE DATABASE $username OWNER $username;"
